.vscode/
*.swp
*.swo
*~

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini

# Node (in case docs/ uses tooling later)
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# PulseCraft runtime outputs (tracked by folder, not contents)
audit/*
!audit/.gitkeep
!audit/eval/
audit/eval/*.txt
queue/*
!queue/.gitkeep

# Claude Code local overrides
.claude/local-settings.json

# Database files (no local DB in this service)
*.db
*.sqlite
*.sqlite3

# Misc
*.log
*.tmp
*.bak
