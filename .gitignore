MANIFEST
pip-wheel-metadata/

# Virtual environments
.venv/
venv/
env/
ENV/
.python-version

# Environment / secrets — never commit
.env
.env.*
*.pem
*.key

# Testing & coverage
.pytest_cache/
.coverage
coverage.xml
*.cover
htmlcov/
.tox/
nosetests.xml

